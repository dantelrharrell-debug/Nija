# NIJA Platform - Production Environment Configuration
# Copy this file to .env and fill in your values

# ========================================
# Database Configuration
# ========================================

# PostgreSQL connection (use one of these methods)
# Method 1: Individual variables
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nija
POSTGRES_USER=nija_user
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# Method 2: Single DATABASE_URL (used by some cloud providers)
# DATABASE_URL=postgresql://nija_user:password@postgres:5432/nija

# ========================================
# JWT Authentication
# ========================================

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRATION_HOURS=24

# ========================================
# API Server Configuration
# ========================================

PORT=8000
DEBUG=false

# CORS allowed origins (comma-separated)
# Examples: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# Trusted hosts for Host header validation
TRUSTED_HOSTS=yourdomain.com,app.yourdomain.com

# ========================================
# Rate Limiting
# ========================================

# Maximum requests per window
RATE_LIMIT_REQUESTS=100

# Time window in seconds
RATE_LIMIT_WINDOW=60

# ========================================
# Redis Configuration
# ========================================

# NIJA uses Redis for the distributed single-writer lock that prevents
# duplicate bot instances from generating conflicting Kraken nonces.
#
# ── Railway deployment (RECOMMENDED) ─────────────────────────────────────
# 1. Add a Redis service in your Railway project.
# 2. Go to Redis service → Connect tab → copy the PUBLIC proxy URL.
#    It looks like:  redis://default:PASSWORD@maglev.proxy.rlwy.net:PORT
# 3. IMPORTANT: change the scheme to rediss:// (TLS) for the public proxy:
#    NIJA_REDIS_URL=rediss://default:PASSWORD@maglev.proxy.rlwy.net:PORT
#
# ⚠️  Common mistakes:
#    • Using redis:// instead of rediss:// for public Railway proxy endpoints.
#      The bot auto-upgrades redis:// → rediss:// for *.proxy.rlwy.net hosts
#      when NIJA_REDIS_FORCE_TLS=true (the default), BUT setting the correct
#      scheme explicitly is safer and avoids any edge-case surprises.
#    • Copying the INTERNAL URL (ends in .railway.internal) — that only works
#      within Railway's private network; the bot cannot reach it from outside.
#    • Leaving wrapping quotes in the value:  NIJA_REDIS_URL="rediss://..."
#      The bot will reject this at startup with a clear error message.
#
# ── Local / Docker deployment ─────────────────────────────────────────────
# NIJA_REDIS_URL=redis://localhost:6379/0
#
# ── Disable distributed locking (UNSAFE — single instance only) ───────────
# If you are certain only one bot instance will ever run and you want to
# skip Redis entirely:
# NIJA_UNSAFE_BYPASS_DISTRIBUTED_LOCK=true
#
# ── Exit immediately on lock failure instead of retrying ──────────────────
# Useful during debugging to get a fast failure instead of an infinite loop:
# NIJA_FAIL_CLOSED_RETRY_ON_LOCK_FAILURE=false

# Set this to your Railway PUBLIC proxy URL (rediss://) or local Redis URL:
NIJA_REDIS_URL=rediss://default:CHANGE_ME_PASSWORD@maglev.proxy.rlwy.net:CHANGE_ME_PORT

# TLS policy — set to false only if your Redis endpoint does not support TLS
NIJA_REDIS_FORCE_TLS=true

# Strict mode — prevents silent fallback to secondary Redis URLs (recommended)
NIJA_STRICT_SINGLE_REDIS_URL=true

# ========================================
# Vault Configuration (Optional)
# ========================================

VAULT_ADDR=http://vault:8200
VAULT_TOKEN=your-vault-token-here

# ========================================
# Master Trading Account (Optional)
# ========================================

# These are optional - for platform operator's own trading
# Users will connect their own accounts via the dashboard

# Coinbase
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Kraken
KRAKEN_PLATFORM_API_KEY=
KRAKEN_PLATFORM_API_SECRET=

# ========================================
# Monitoring & Logging
# ========================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ========================================
# Email Configuration (Future)
# ========================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=noreply@yourdomain.com

# ========================================
# Stripe Payment Configuration (Future)
# ========================================

# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ========================================
# Security Notes
# ========================================

# 1. Never commit .env files to version control
# 2. Use strong, unique passwords (16+ characters)
# 3. Generate random JWT secret (64+ characters)
# 4. Restrict ALLOWED_ORIGINS to your actual domains
# 5. Enable HTTPS in production
# 6. Rotate secrets regularly
# 7. Use environment-specific configurations

# ========================================
# Cloud Provider Specific
# ========================================

# Railway automatically provides DATABASE_URL
# Heroku automatically provides DATABASE_URL
# For other providers, configure manually above
