# NIJA Platform - Production Environment Configuration
# Copy this file to .env and fill in your values

# ========================================
# Database Configuration
# ========================================

# PostgreSQL connection (use one of these methods)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nija
POSTGRES_USER=nija_user
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# Single DATABASE_URL alternative
# DATABASE_URL=postgresql://nija_user:password@postgres:5432/nija

# ========================================
# JWT Authentication
# ========================================

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRATION_HOURS=24

# ========================================
# API Server Configuration
# ========================================

PORT=8000
DEBUG=false
ALLOWED_ORIGINS=https://yourdomain.com
TRUSTED_HOSTS=yourdomain.com,app.yourdomain.com

# ========================================
# Redis / Single Writer Authority
# ========================================

# REQUIRED for live trading. NIJA uses Redis for the distributed single-writer
# lock that prevents duplicate instances from generating conflicting nonces and
# duplicate orders.
NIJA_REDIS_URL=rediss://default:CHANGE_ME_PASSWORD@maglev.proxy.rlwy.net:CHANGE_ME_PORT
NIJA_REDIS_FORCE_TLS=true
NIJA_STRICT_SINGLE_REDIS_URL=true
NIJA_REQUIRE_DISTRIBUTED_LOCK=true
NIJA_STRICT_REDIS_LEASE=1
NIJA_UNSAFE_BYPASS_DISTRIBUTED_LOCK=false
NIJA_DISABLE_WRITER_LOCK=false
NIJA_FORCE_LOCAL_WRITER_LOCK_FALLBACK=false
NIJA_REDIS_LEASE_FORCE_TAKEOVER=0
NIJA_FAIL_CLOSED_RETRY_ON_LOCK_FAILURE=true
NIJA_FAIL_CLOSED_EXIT_ON_UNREACHABLE_REDIS=true
NIJA_FAIL_CLOSED_MAX_RETRY_ATTEMPTS=12

# Emergency only. Do not enable in production unless all other instances are
# stopped and you intentionally accept duplicate-order risk.
NIJA_CONFIRM_BYPASS_RISKS=false

# ========================================
# Live Trading Mode
# ========================================

DRY_RUN_MODE=false
PAPER_MODE=false
LIVE_CAPITAL_VERIFIED=true
NIJA_EXECUTION_ACTIVE=true
NIJA_RUNTIME_EXECUTION_AUTHORITY=true

# Keep all configured live brokers enabled/isolated.
ENABLE_KRAKEN_TRADING=true
KRAKEN_LIVE_TRADING_ENABLED=true
ENABLE_COINBASE_TRADING=true
COINBASE_LIVE_TRADING_ENABLED=true
ENABLE_OKX_TRADING=true
OKX_LIVE_TRADING_ENABLED=true
OKX_BASE_URL=https://us.okx.com
OKX_US_REGION=true

# Live order minimums: prevents below-min-notional and fee-economics rejects.
MIN_TRADE_USD=50
MIN_CASH_TO_BUY=50
KRAKEN_MIN_NOTIONAL_USD=50
COINBASE_MIN_ORDER_USD=50
OKX_MIN_ORDER_USD=50
NIJA_PENDING_ORDER_TIMEOUT_S=90

# Strategy mode
HF_SCALP_MODE=1
HF_SCALPING_MODE=1
FORCE_TRADE=false
FORCE_TRADE_MODE=false
NIJA_FORCE_ACTIVATION=false

# ========================================
# Broker Credentials
# ========================================

# Coinbase Advanced Trade
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Kraken platform account
KRAKEN_PLATFORM_API_KEY=
KRAKEN_PLATFORM_API_SECRET=

# OKX platform account
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# ========================================
# Runtime Safety / Observability
# ========================================

NIJA_STARTUP_POSITION_SYNC_ENABLED=true
NIJA_BROKER_SCOPED_POSITION_CAP=true
NIJA_PROFITABILITY_GUARD_ENABLED=true
NIJA_LOG_TRADE_DECISIONS=true
NIJA_CYCLE_SUMMARY_INTERVAL=10
NIJA_VETO_SUMMARY_INTERVAL=50
LOG_LEVEL=INFO

# ========================================
# Monitoring & Logging
# ========================================

SENTRY_DSN=

# ========================================
# Email Configuration (Future)
# ========================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=noreply@yourdomain.com

# ========================================
# Stripe Payment Configuration (Future)
# ========================================

# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ========================================
# Security Notes
# ========================================

# 1. Never commit real .env files to version control
# 2. Use strong, unique passwords and API keys
# 3. Generate random JWT secret (64+ characters)
# 4. Restrict ALLOWED_ORIGINS to your real domains
# 5. Enable HTTPS in production
# 6. Rotate secrets regularly
# 7. Keep Railway replicas at 1 unless using strict Redis writer authority
