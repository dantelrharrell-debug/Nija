# .env.example - copy to .env and fill with real values (do NOT commit .env)
#
# ============================================================================
# QUICK START PRESETS
# ============================================================================
# For specific use cases, you can use these preset configuration templates:
#
# 1. PLATFORM_ONLY Mode (A+ setups, BTC/ETH/SOL only, 3-5% risk)
#    Copy: cp .env.master_only .env
#    Guide: See PLATFORM_ONLY_GUIDE.md
#
# 2. Small Account Preset ($50-$250 accounts)
#    Copy: cp .env.small_account_preset .env
#    Guide: See SMALL_ACCOUNT_QUICKSTART.md
#
# Or customize this .env.example file for your specific needs
# ============================================================================

# ============================================================================
# KRAKEN EXCHANGE - PRIMARY BROKER
# ============================================================================
# Get credentials from: https://www.kraken.com/u/security/api
#
# IMPORTANT: Must use "Classic API Key" (NOT OAuth or App keys)
# To create: Settings > API > Generate New Key
#
# Required Permissions (ALL must be enabled):
#   ✅ Query Funds
#   ✅ Query Open Orders & Trades
#   ✅ Query Closed Orders & Trades
#   ✅ Create & Modify Orders
#   ✅ Cancel/Close Orders
#   ❌ Do NOT enable "Withdraw Funds"
#
# ============================================================================
# 🏦  SMART STRUCTURE — Run NIJA as a Real SaaS Platform
# ============================================================================
#
#   Kraken Account 1
#     Owner  : You
#     Purpose: Personal investing
#     → Connect as a user account below (KRAKEN_USER_YOURNAME_*)
#
#   Kraken Account 2
#     Owner  : NIJA
#     Purpose: AI trading engine  ← this is the PLATFORM account
#     → Set credentials here (KRAKEN_PLATFORM_API_KEY / SECRET)
#
#   User connections:
#     User Kraken ──► API ──► NIJA
#     Any user can link their own Kraken account to NIJA using the
#     KRAKEN_USER_{FIRSTNAME}_* pattern below.
#
# See SMART_STRUCTURE_GUIDE.md for step-by-step setup.
# ============================================================================
#
# ── NIJA PLATFORM ACCOUNT (Kraken Account 2 — AI trading engine) ──────────
# This is NIJA's own Kraken account.  It runs the AI trading engine and is
# the primary account in the SaaS hierarchy.
#
# FORMAT: alphanumeric string from kraken.com/u/security/api
#   Key example:   AbCdEfGhIjKlMnOp  (16+ chars)
#   Secret example: 64+ character base64 string (longer than the key)
#
# ⚠️  NIJA will REFUSE TO START if these are left empty or contain
#     placeholder text like "your_api_key_here".
KRAKEN_PLATFORM_API_KEY=
KRAKEN_PLATFORM_API_SECRET=
#
# ── USER ACCOUNTS (User Kraken → API → NIJA) ──────────────────────────────
# These are the personal Kraken accounts that users connect to NIJA.
# Kraken Account 1 (your personal account) goes here, as do any other users.
#
# Format: KRAKEN_USER_{FIRSTNAME}_API_KEY / _API_SECRET
# The {FIRSTNAME} is taken from the first part of the user_id in
#   config/users/retail_kraken.json
# Example: user_id "daivon_frazier"  →  KRAKEN_USER_DAIVON_*
#
# ── Your personal account (Kraken Account 1 → NIJA) ──
KRAKEN_USER_YOURNAME_API_KEY=
KRAKEN_USER_YOURNAME_API_SECRET=
#
# ── Additional connected users ────────────────────────
KRAKEN_USER_DAIVON_API_KEY=
KRAKEN_USER_DAIVON_API_SECRET=
#
KRAKEN_USER_TANIA_API_KEY=
KRAKEN_USER_TANIA_API_SECRET=
#
# Add more users by following the pattern:
# KRAKEN_USER_{FIRSTNAME}_API_KEY=
# KRAKEN_USER_{FIRSTNAME}_API_SECRET=
#
# Legacy credentials (for backward compatibility, optional):
# Only used if KRAKEN_PLATFORM_* not set.
# These also pass NIJA's startup viability check as a fallback.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ============================================================================
# KRAKEN TRADING CONFIGURATION (Safety Tuning)
# ============================================================================
# Kraken-specific aggressiveness tuning (Jan 30, 2026)
# These parameters provide safer, more conservative thresholds for Kraken trading
# Adjust these values to tune trade quality vs frequency
#
# RSI Range Configuration:
# KRAKEN_MIN_RSI: Lower value = more aggressive (allows lower RSI, wider range on low end)
# KRAKEN_MAX_RSI: Higher value = more aggressive (allows higher RSI, wider range on high end)
# Default: 35-65 (more conservative than general 30-70)
KRAKEN_MIN_RSI=35  # Minimum RSI for trade entry (avoid extreme oversold)
KRAKEN_MAX_RSI=65  # Maximum RSI for trade entry (avoid extreme overbought)
#
# Confidence Threshold (default: 0.65, higher than general 0.60)
# - Lower values = more trades (more aggressive)
# - Higher values = fewer but higher quality trades (more conservative)
KRAKEN_MIN_CONFIDENCE=0.65  # Minimum confidence score (0.0-1.0)
#
# Volatility Threshold (default: 0.6%, higher than general 0.5%)
# - Lower values = more trades in calmer markets
# - Higher values = only trade in volatile markets (better R:R)
KRAKEN_MIN_ATR_PCT=0.6  # Minimum ATR as percentage (e.g., 0.6 = 0.6%)

# ============================================================================
# KRAKEN NONCE MANAGER TUNING (Advanced — keep defaults unless troubleshooting)
# ============================================================================
# Full documentation: bot/global_kraken_nonce.py
#
# ── Startup / reset offsets ────────────────────────────────────────────────
# ms added to the persisted nonce value on every hot restart
# NIJA_NONCE_STARTUP_JUMP_MS=10000
# ms offset used by reset_to_safe_value() (manual recovery helper)
# NIJA_NONCE_RESET_OFFSET_MS=300000
#
# ── Nuclear reset policy ───────────────────────────────────────────────────
# Consecutive nonce errors required to trigger a nuclear (30-min) reset
# NIJA_NONCE_NUCLEAR_THRESHOLD=5
# Forward-jump size (ms) applied by a nuclear reset (default: 30 min)
# NIJA_NONCE_NUCLEAR_OFFSET_MS=1800000
# Trading pause (seconds) after a nuclear reset while Kraken's window catches up
# NIJA_NONCE_PAUSE_SECONDS=300
# Consecutive errors required before any forward jump fires (< this = no jump)
# NIJA_NONCE_ERROR_RESET_THRESHOLD=3
#
# ── Auto deep-reset / quarantine thresholds ───────────────────────────────
# Nuclear resets per session before deep-probe mode auto-activates (120 min coverage)
# NIJA_AUTO_DEEP_THRESHOLD=2
# Nuclear resets per session before the Kraken broker is quarantined (exit-only)
# NIJA_NONCE_QUARANTINE_THRESHOLD=2
#
# ── Probe-and-resync parameters ────────────────────────────────────────────
# Step size (ms) per standard probe attempt (default: 5 min)
# NIJA_NONCE_PROBE_STEP_MS=300000
# Maximum standard probe attempts (default: 12 → 60 min coverage)
# NIJA_NONCE_PROBE_MAX_ATTEMPTS=12
# Step size (ms) per deep-probe attempt (default: 10 min)
# NIJA_NONCE_DEEP_STEP_MS=600000
# Maximum deep-probe attempts (default: 12 → 120 min coverage)
# NIJA_NONCE_DEEP_MAX_ATTEMPTS=12
# Startup nonce floor (ms ahead of wall-clock) when deep-reset is active
# NIJA_NONCE_DEEP_STARTUP_FLOOR_MS=3600000
# Extra probe attempts added when a duplicate process holds the nonce lock
# NIJA_NONCE_DUPLICATE_PROC_EXTRA_ATTEMPTS=6
#
# ── Ceiling jump (last resort) ─────────────────────────────────────────────
# Activate a one-time ceiling jump on startup: NIJA_NONCE_CEILING_JUMP=1
# Size (ms) of the ceiling jump (default: 24 h)
# NIJA_NONCE_CEILING_JUMP_MS=86400000
#
# ── Adaptive Offset Engine ─────────────────────────────────────────────────
# Startup delay used by the offset engine's timing floor (ms)
# NIJA_AO_STARTUP_DELAY_MS=15000
# Max jitter component (ms)
# NIJA_AO_JITTER_MS=5000
# Retry buffer (ms) — 5 retries × 5 s
# NIJA_AO_RETRY_BUFFER_MS=25000
# Safety margin added above the observed nonce gap (ms)
# NIJA_AO_SAFETY_MARGIN_MS=60000
# EMA alpha: weight of the most recent calibration observation (0–1)
# NIJA_AO_EMA_ALPHA=0.3
# Number of historical calibration records to persist
# NIJA_AO_HISTORY_WINDOW=10
#
# ── Corruption guard ───────────────────────────────────────────────────────
# If persisted nonce is this far ahead of wall-clock → warn but keep (ms)
# NIJA_NONCE_CORRUPTION_WARN_MS=600000
# If persisted nonce is this far ahead of wall-clock → discard and restart (ms)
# NIJA_NONCE_CORRUPTION_RESET_MS=259200000

# ============================================================================
# COINBASE EXCHANGE
# ============================================================================
# Get credentials from: https://portal.cdp.coinbase.com/
#
# New API format (Cloud API Key) — RECOMMENDED:
#   COINBASE_API_KEY    = organizations/{org_id}/apiKeys/{key_id}
#   COINBASE_API_SECRET = -----BEGIN EC PRIVATE KEY-----\n<base64 body>\n-----END EC PRIVATE KEY-----
#     Note: In Railway/Docker environment variables, use literal \n (backslash-n)
#     to represent newlines inside the PEM block.  Example:
#       COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nMHQCAQEEI...\n-----END EC PRIVATE KEY-----
#
# Required permissions: View, Trade
#
# ⚠️  NIJA will REFUSE TO START if these are left empty or contain
#     placeholder text.
COINBASE_API_KEY=
COINBASE_API_SECRET=
#
# Legacy JWT format (if using older credentials):
# COINBASE_ORG_ID=
# COINBASE_JWT_PEM="-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----"
# COINBASE_JWT_KID=
# COINBASE_JWT_ISSUER=
#
# Optional overrides
# COINBASE_API_BASE=  # set if you need a different base than default brokerage path
#
# Portfolio selection (optional)
# Set this to the UUID of a specific portfolio to use for trading
# Use find_usd_portfolio.py to list all portfolios and their UUIDs
COINBASE_RETAIL_PORTFOLIO_ID=
#
# Balance detection (optional)
# By default, consumer/retail USD accounts are excluded from trading balance
# Set to "true" or "1" to include consumer USD accounts in trading balance
ALLOW_CONSUMER_USD=False

# ============================================================================
# ALPACA TRADING (Stocks)
# ============================================================================
# Get credentials from: https://alpaca.markets/
# Use paper trading credentials for testing
#
# MASTER ACCOUNT (Nija system trading account):
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true  # Set to false for live trading
#
# USER ACCOUNTS (Individual user/investor accounts):
# Format: ALPACA_USER_{FIRSTNAME}_API_KEY
# The {FIRSTNAME} is extracted from the user_id in config/users/alpaca_users.json
#
ALPACA_USER_TANIA_API_KEY=
ALPACA_USER_TANIA_API_SECRET=
ALPACA_USER_TANIA_PAPER=true  # Set to false for live trading
#
# Add more users by following the pattern:
# ALPACA_USER_{FIRSTNAME}_API_KEY=
# ALPACA_USER_{FIRSTNAME}_API_SECRET=
# ALPACA_USER_{FIRSTNAME}_PAPER=true
#
# For testing, use these paper trading credentials:
# ALPACA_API_KEY=PKS2NORMEX6BMN6P3T63C7ICZ2
# ALPACA_API_SECRET=GPmZyiXDoP3A8VcsjcdiCcmdBdzFQnBsmyGSTFQpWyPJ
# ALPACA_PAPER=true

# ============================================================================
# OKX EXCHANGE (Optional)
# ============================================================================
# Get credentials from: https://www.okx.com/account/my-api
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_USE_TESTNET=false  # Set to true for demo trading

# ============================================================================
# BINANCE EXCHANGE (Optional)
# ============================================================================
# Get credentials from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_USE_TESTNET=false  # Set to true for demo trading

# ============================================================================
# SECURITY CONFIGURATION (REQUIRED FOR PRODUCTION)
# ============================================================================
# These environment variables are REQUIRED for secure operation.
# The application will fail to start if they are not set properly.

# JWT Secret Key (REQUIRED)
# Used to sign and verify JSON Web Tokens for API authentication
# SECURITY: Must be at least 32 characters long
# Generate with: openssl rand -hex 32
# IMPORTANT: Keep this secret secure - if compromised, all JWTs are invalid
JWT_SECRET_KEY=

# JWT Token Expiration (Optional)
# How long JWT tokens remain valid (in hours)
# Default: 24 hours
# Shorter values = more secure but users must re-authenticate more frequently
JWT_EXPIRATION_HOURS=24

# TradingView Webhook Secret (REQUIRED for TradingView alerts)
# Used to authenticate incoming TradingView webhook alerts
# Set the same value in your TradingView alert webhook message JSON: {"secret": "<value>"}
# SECURITY: Must be a strong random secret — never use a guessable value
# Generate with: openssl rand -hex 32
TRADINGVIEW_WEBHOOK_SECRET=

# CORS Allowed Origins (REQUIRED for web frontend)
# Comma-separated list of allowed origins for CORS
# Example: https://app.yourdomain.com,https://dashboard.yourdomain.com
# SECURITY: Never use '*' in production - only allow specific domains
# For local development: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=

# Trusted Hosts (Optional but recommended)
# Comma-separated list of trusted hostnames
# Example: nija-bot.railway.app,api.yourdomain.com
# SECURITY: Helps prevent host header injection attacks
TRUSTED_HOSTS=

# ============================================================================
# SECRETS BACKEND (Production Secrets Management)
# ============================================================================
# Controls where application secrets (JWT_SECRET_KEY, VAULT_ENCRYPTION_KEY,
# etc.) are fetched from at runtime.
#
#   env    (default) – plain environment variables / .env file  ← dev
#   aws              – AWS Secrets Manager                      ← cloud prod
#   vault            – HashiCorp Vault                          ← enterprise
#
# Example: SECRETS_BACKEND=aws
SECRETS_BACKEND=env

# ── AWS Secrets Manager (SECRETS_BACKEND=aws) ───────────────────────────────
# Standard boto3 credential chain is used (IAM role, ~/.aws/credentials, or
# the env vars below).  In production use an IAM role – do NOT hard-code keys.
#
# AWS_REGION=us-east-1
# AWS_SECRET_NAME_PREFIX=nija/          # prefix for all secret names (default)
# AWS_ACCESS_KEY_ID=                    # dev / CI only – prefer IAM roles
# AWS_SECRET_ACCESS_KEY=               # dev / CI only – prefer IAM roles

# ── HashiCorp Vault (SECRETS_BACKEND=vault) ─────────────────────────────────
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_SECRET_PATH_PREFIX=secret/nija/ # KV v2 path prefix (default)
# VAULT_NAMESPACE=                      # Vault Enterprise namespace (optional)
#
# Authentication – choose ONE of the following:
#   Static token (dev / CI only):
#     VAULT_TOKEN=
#
#   AppRole (recommended for production):
#     VAULT_ROLE_ID=
#     VAULT_SECRET_ID=

# ============================================================================
# RATE LIMITING (Production)
# ============================================================================
# By default, rate limiting uses an in-process memory store which does NOT
# persist across worker processes or restarts.  For production, set this to a
# Redis URL so all workers share a single rate-limit counter.
#
# Example: RATELIMIT_STORAGE_URI=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://


# ============================================================================
# APP STORE MODE - Apple App Review Safety
# ============================================================================
# Enable App Store review mode to block all live trading execution.
# When enabled, the app is safe for Apple App Store review:
#   ✅ Dashboard and UI fully functional
#   ✅ Read-only APIs accessible
#   ✅ Trade simulation visible
#   ✅ Risk disclosures shown
#   ❌ NO real money trades executed
#
# CRITICAL: Set to 'true' ONLY during App Store review submission
# Set to 'false' for normal live trading operation
#
# Default: false (live trading allowed - for production use)
APP_STORE_MODE=false

# ============================================================================
# BOT CONFIGURATION
# ============================================================================

# TRADING MODE - Independent Trading Model
# Defines how the bot operates in multi-account scenarios.
# Values:
#   - independent: Each account evaluates markets independently using the same
#                  algorithmic strategy. No trade copying or signal distribution.
# Default: independent (see FEATURE_FLAGS.md for details)
# Security: Ensures no hierarchical trading models that could trigger regulatory concerns
TRADING_MODE=independent


# CRITICAL SAFETY: LIVE CAPITAL VERIFIED Kill-Switch
# This is the MASTER safety control that must be explicitly enabled for live trading.
# Set to 'true' only when you have verified that:
#   1. All API credentials are correct
#   2. You understand the risks of live trading
#   3. You are ready to trade with real capital
# Default: false (trading disabled - safe mode)
# Set to true to enable live trading (also accepted: LIVE_TRADING=1 below)
LIVE_CAPITAL_VERIFIED=true

# LIVE TRADING CONFIRMATION
# Optional when running start.sh in a non-interactive (CI/CD) environment with
# LIVE_CAPITAL_VERIFIED=true. Setting this to true suppresses the approval message
# shown when LIVE_CAPITAL_VERIFIED=true is used in a non-interactive session.
# In interactive terminals, start.sh will prompt for confirmation instead.
# Default: false (LIVE_CAPITAL_VERIFIED=true is sufficient for non-interactive sessions)
LIVE_TRADING_CONFIRMED=false

# HEARTBEAT TRADE - Verification Mode
# Enable a single tiny test trade to verify bot connectivity and trading functionality
# When enabled, the bot will execute ONE small trade (typically $5-10) and then disable itself
# This is useful for verifying:
#   1. API credentials are working correctly
#   2. Trading logic is functioning
#   3. Orders can be placed and executed
# IMPORTANT: Disable this after the heartbeat trade completes to resume normal trading
# Default: false (disabled)
HEARTBEAT_TRADE=false

# APP STORE MODE - Read-Only Demo Mode for App Store Reviewers
# Enable this mode for App Store submission and review
# When enabled, the app:
#   1. Displays all dashboards and metrics (visible, read-only)
#   2. Disables all trade execution buttons (no real trades)
#   3. Shows prominent risk disclosures
#   4. Allows simulator/sandbox trades to demonstrate functionality
#   5. Prevents any real money trading operations
# This mode is REQUIRED for:
#   - Apple App Store review process
#   - Google Play Store review process
#   - Public demo/presentation mode
# Default: false (disabled - full functionality mode)
APP_STORE_MODE=false

# DRY-RUN SIMULATOR MODE - App Store Review Mode
# Enable simulated trading mode for App Store reviewers and testing
# When enabled, the bot:
#   1. Evaluates signals normally using live market data
#   2. Tracks last evaluated trade for UI display
#   3. DOES NOT place real orders - all trades are simulated
#   4. Shows trading logic and decision-making without real money
# This mode is perfect for:
#   - App Store review process
#   - Testing strategy logic
#   - Demonstrating bot functionality safely
# Default: false (disabled - real trading mode)
DRY_RUN_MODE=false
# Heartbeat Trade (Verification & Health Check)
# When enabled, the bot executes a tiny test trade periodically to verify:
#   - Exchange connectivity is working
#   - Order execution is functioning
#   - API credentials are valid
# This is useful for:
#   - Verifying new deployments (enable briefly, confirm 1 trade, then disable)
#   - Monitoring exchange connectivity health
# Default: false (disabled)
# Set to true only for verification, then disable after confirming execution
HEARTBEAT_TRADE=false
# Heartbeat trade size in USD (default: $5.50 - minimum viable trade)
HEARTBEAT_TRADE_SIZE=5.50
# Heartbeat trade interval in seconds (default: 600 = 10 minutes)
HEARTBEAT_TRADE_INTERVAL=600

LIVE_TRADING=1
RETRY_DELAY=5
MAX_RETRIES=5
MIN_TRADE_PERCENT=0.02
MAX_TRADE_PERCENT=0.10
DEFAULT_TRADE_PERCENT=0.02

# Position Management
MAX_CONCURRENT_POSITIONS=7
MIN_CASH_TO_BUY=5.50
MINIMUM_TRADING_BALANCE=25.0
REENTRY_COOLDOWN_MINUTES=120

# Small Account Configuration
# For accounts under $25, you can lower these minimums:
# MINIMUM_TRADING_BALANCE=15.0  # Minimum balance to start trading (default: 25.0)
# MIN_CASH_TO_BUY=5.0           # Minimum cash to place buy order (default: 5.50)

# Multi-Broker Independent Trading
# When enabled, each broker runs in its own isolated thread
# Failures in one broker won't affect trading on other brokers
MULTI_BROKER_INDEPENDENT=true

# Suppress Single Exchange Warning
# Set to "true" or "1" to suppress the warning when only one exchange is connected
# Default: false (show warning to encourage multi-exchange trading)
SUPPRESS_SINGLE_EXCHANGE_WARNING=false

# ============================================================================
# PRO MODE - Position Rotation Trading (ADVANCED)
# ============================================================================
# PRO MODE enables hedge-fund style position rotation:
#   - Open position values count as available capital
#   - Bot can close weak positions to fund better opportunities
#   - Never locks all capital (maintains minimum free reserve)
#   - Uses total capital (free + positions) for position sizing
#
# ⚠️  RISK WARNING: More aggressive trading, higher complexity
# ✅  BENEFIT: Never "starves" by having all capital locked in positions
#
# Enable/disable PRO MODE
PRO_MODE=true
#
# Minimum free balance reserve % (default: 15%)
# Bot will maintain at least this % of total capital as free USD
# Example: With $100 total capital and 15% reserve, bot keeps minimum $15 free
PRO_MODE_MIN_RESERVE_PCT=0.15

# Initial Capital Configuration
# INITIAL_CAPITAL determines how the system tracks starting capital.
# Options:
#   - auto: Use live broker balance automatically (RECOMMENDED - most accurate)
#   - LIVE: Same as "auto" - uses live broker balance (alias for compatibility)
#   - <number>: Set explicit starting capital (e.g., 100, 250, 1000)
#
# RECOMMENDATION: Set to "auto" for clean user accounting with real-time balance
# For STARTER tier ($50-$99), this requirement is waived.
#
# RECOMMENDATION: Set to "auto" for clean user accounting with real-time balance
INITIAL_CAPITAL=auto

# Disabled Trading Pairs
# Comma-separated list of pairs to disable globally (e.g., XRP-USD for small accounts)
# XRP is disabled by default on ALL exchanges due to high spreads and low profit potential
# Note: Individual users can also configure disabled_symbols in their user config JSON files
# Global disabled pairs are hardcoded in trading_strategy.py + additional pairs from this env var
DISABLED_PAIRS=XRP-USD

# ============================================================================
# SYMBOL WHITELIST (OPTIONAL - FOR FOCUSED TRADING)
# ============================================================================
# Enable symbol whitelist to only trade specific cryptocurrencies
# When enabled, ONLY the symbols in the whitelist will be traded
# This is useful for focused strategies (e.g., BTC/ETH/SOL only)
#
# Set to "true" to enable whitelist mode (see bot/master_only_config.py)
# Default: false (trade all available symbols except blacklisted)
ENABLE_SYMBOL_WHITELIST=false
#
# The whitelist is defined in bot/master_only_config.py
# Default whitelist: BTC-USD, ETH-USD, SOL-USD
#
# See PLATFORM_ONLY_GUIDE.md for the complete PLATFORM_ONLY mode setup

# ============================================================================
# STABLECOIN TRADING POLICY
# ============================================================================
# Configure how NIJA handles stablecoin trading pairs (USDT, USDC, DAI, BUSD)
#
# Available policies:
#   - route_to_kraken: Route all stablecoin trades to Kraken (lower fees, recommended)
#   - block_all: Block all stablecoin trading pairs
#   - allow_all: Allow stablecoin trades on any configured broker
#
# Default: route_to_kraken
STABLECOIN_POLICY=route_to_kraken

# ============================================================================
# TIER-BASED MINIMUM TRADE SIZES
# ============================================================================
# Minimum visible trade size per tier (trades smaller than this are executed
# but not shown prominently in the activity feed)
#
# Tier structure:
#   STARTER ($50-$99):    Min visible: $10, Max risk: 10-15%
#   SAVER ($100-$249):    Min visible: $15, Max risk: 7-10%
#   INVESTOR ($250-$999): Min visible: $20, Max risk: 5-7%
#   INCOME ($1k-$5k):     Min visible: $30, Max risk: 3-5%
#   LIVABLE ($5k-$25k):   Min visible: $50, Max risk: 2-3%
#   BALLER ($25k+):       Min visible: $100, Max risk: 1-2%
#
# ⚠️ IMPORTANT: Master account is ALWAYS BALLER tier regardless of balance
# This provides the best risk management parameters (1-2% max risk per tier guidelines)
# with the global 15% max trade size cap still enforced
#
# These are automatically applied based on account balance for user accounts
# No manual configuration needed - NIJA detects tier from balance
#
# ADVANCED: Force a specific tier for user accounts (bypasses auto-detection)
# Useful for small user accounts that need better risk management of higher tiers
# Set to: STARTER, SAVER, INVESTOR, INCOME, LIVABLE, BALLER, or MASTER
# Leave empty or commented out for automatic tier detection
# For master account: Set to BALLER or MASTER (both enforce BALLER tier)
# Example: PLATFORM_ACCOUNT_TIER=BALLER
PLATFORM_ACCOUNT_TIER=BALLER

# ============================================================================
# NOTES ON USER CONFIGURATION
# ============================================================================
#
# USER ACCOUNTS are configured in JSON files, not in this .env file:
#   - config/users/retail_kraken.json - Retail users on Kraken
#   - config/users/retail_alpaca.json - Retail users on Alpaca
#   - config/users/retail_coinbase.json - Retail users on Coinbase
#   - config/users/investor_kraken.json - Investor accounts on Kraken
#   - config/users/investor_alpaca.json - Investor accounts on Alpaca
#   - config/users/investor_coinbase.json - Investor accounts on Coinbase
#
# To add a new user:
# 1. Edit the appropriate JSON file in config/users/
# 2. Add the user's credentials to this .env file following the pattern above
# 3. Restart the bot
#
# See USER_SETUP_GUIDE.md for detailed instructions.
#
# Environment variable naming pattern:
#   {BROKER}_USER_{FIRSTNAME}_API_KEY
#   {BROKER}_USER_{FIRSTNAME}_API_SECRET
#
# Example:
#   user_id: "jane_smith" in retail_kraken.json
#   Environment variables:
#     KRAKEN_USER_JANE_API_KEY=...
#     KRAKEN_USER_JANE_API_SECRET=...
#
# The {FIRSTNAME} is extracted from user_id (part before first underscore, uppercase)

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Control optional features and experimental functionality
# Format: FEATURE_{FLAG_NAME}=true|false
#
# Available Feature Flags:
#
# PROFIT_CONFIRMATION - Profit Confirmation Logging
# Enables detailed tracking and logging of profit confirmations with metrics
# When enabled: Tracks profit confirmations, givebacks, and generates reports
# When disabled: Skips profit confirmation tracking (lightweight mode)
# Default: true (recommended for production trading)
# Can also be imported from config.feature_flags import PROFIT_CONFIRMATION_AVAILABLE
FEATURE_PROFIT_CONFIRMATION=true
#
# ENTRY_QUALITY_AUDIT - Entry Quality Auditing (Experimental)
# Default: false
# FEATURE_ENTRY_QUALITY_AUDIT=false
#
# VOLATILITY_ADAPTIVE_SIZING - Volatility-Based Position Sizing (Experimental)
# Default: false
# FEATURE_VOLATILITY_ADAPTIVE_SIZING=false
#
# DYNAMIC_STOP_EXPANSION - Dynamic Stop Loss Expansion (Experimental)
# Default: false
# FEATURE_DYNAMIC_STOP_EXPANSION=false
#
# LIVE_DASHBOARD - Live Trading Dashboard (Experimental)
# Default: false
# FEATURE_LIVE_DASHBOARD=false
#
# Note: Safety features (PROFITABILITY_ASSERTION, STOP_LOSS_VALIDATION) are
# always enabled and cannot be disabled via feature flags.

# ============================================================================
# FORCED CLEANUP CONFIGURATION
# ============================================================================
# Control how forced cleanup handles positions with open orders
# By default, forced cleanup is conservative and won't cancel open orders
#
# FORCED_CLEANUP_CANCEL_OPEN_ORDERS - Enable open order cancellation
# When enabled, forced cleanup will cancel open orders for positions that meet cleanup criteria
# When disabled (default), positions with open orders are skipped during cleanup
# Default: false (conservative - preserves open orders)
FORCED_CLEANUP_CANCEL_OPEN_ORDERS=false
#
# FORCED_CLEANUP_STARTUP_ONLY - Nuclear mode (startup-only cleanup)
# When enabled with FORCED_CLEANUP_CANCEL_OPEN_ORDERS=true, cancels open orders ONLY on startup
# This is a one-time normalization that runs once when the bot starts
# After startup, cleanup reverts to conservative mode (no open order cancellation)
# Use this for initial cleanup of legacy positions, then disable for normal operation
# Default: false (cleanup runs periodically)
FORCED_CLEANUP_STARTUP_ONLY=false
#
# FORCED_CLEANUP_CANCEL_OPEN_ORDERS_IF - Selective cancellation mode (advanced)
# Fine-grained control over which open orders get cancelled during cleanup
# Format: Comma-separated conditions (e.g., "usd_value<1.0,rank>max_positions")
# Available conditions:
#   - usd_value<X: Cancel if position USD value is less than X
#   - rank>max_positions: Cancel if position is ranked for cap pruning
# Example: "usd_value<1.0,rank>max_positions" (recommended for production)
# If set, this overrides FORCED_CLEANUP_CANCEL_OPEN_ORDERS (becomes selective mode)
# Default: empty (use FORCED_CLEANUP_CANCEL_OPEN_ORDERS setting)
# FORCED_CLEANUP_CANCEL_OPEN_ORDERS_IF=usd_value<1.0,rank>max_positions

# ============================================================================
# DISCIPLINED INCUBATION MODE
# ============================================================================
# Activates a conservative, fully-disciplined trading profile:
#   • Spot trading only (no shorts / futures)
#   • 0.5 %–1 % risk per trade
#   • Max 5–8 concurrent positions
#   • 40 % max correlation-group exposure cap
#   • ATR-adjusted position sizing active
#   • VaR breach auto-size reduction (75 % at 95 % breach, 50 % at 99 % breach)
#   • Drawdown circuit breaker enforced (halts at 15 % drawdown)
#
# Set to true to enable:
INCUBATION_MODE=false
#
# SPOT_ONLY - Block short-selling independent of INCUBATION_MODE.
# When INCUBATION_MODE=true, SPOT_ONLY is automatically enforced.
# Set to true to restrict trading to buy/long orders only:
SPOT_ONLY=false

# RECOVERY_MODE - Force the Recovery Controller into RECOVERY state at startup.
# Use this when you need the bot to immediately operate in recovery mode without
# waiting for the FSM to arrive there through normal failure-driven transitions.
#
# In RECOVERY state:
#   - No new trade entries are allowed
#   - Existing positions can still be exited
#   - Log output shows: "ENTRY UNKNOWN – RECOVERY FORCED"
#
# IMPORTANT: "Trading globally disabled" (RECOVERY_MODE=false + GLOBAL_TRADING_ENABLED=false)
# is intentionally DISTINCT from RECOVERY state.  Setting RECOVERY_MODE=true is the
# only config-based way to activate RECOVERY state.
#
# Set to true to activate recovery mode at startup:
RECOVERY_MODE=false


# PostgreSQL connection settings for user management and platform features
# If not using multi-user features, these can be left unset
#
# Option 1: Use complete DATABASE_URL (recommended for cloud platforms)
# ⚠️  SECURITY: DATABASE_URL must include valid credentials (username:password)
# DATABASE_URL=postgresql://username:password@hostname:5432/database_name
#
# Option 2: Use individual components (will be combined into DATABASE_URL)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=nija
# POSTGRES_USER=nija_user
# POSTGRES_PASSWORD=your_secure_password_here  # REQUIRED if using individual components
#
# ⚠️  SECURITY REQUIREMENT:
# A password is MANDATORY for database security, whether using:
# - DATABASE_URL (must contain :password@ in the URL)
# - Individual components (POSTGRES_PASSWORD must be set)
# The database will not start without valid credentials to prevent security vulnerabilities

# ============================================================================
# HF FLIP MODE — High-Frequency Fast Daily Profit Mode
# ============================================================================
# One-switch bundle: set HF_FLIP_MODE=1 to activate all speed-optimisation
# layers simultaneously for maximum daily trade throughput.
#
# What it enables:
#   • Min R:R lowered to 1.3 (from 2.0)
#   • AI confidence gate lowered to 0.33 (from 0.55)
#   • Sniper filter confidence relaxed to 0.35 (from 0.50)
#   • Sniper ADX minimum relaxed to 8 (from 12)
#   • Aggression mode → AGGRESSIVE
#   • Trade frequency targets raised (6/hr, 80/day)
#   • Scan cycle shortened to 20 s
#   • Min net-profit gate dropped to 0.4%
#   • TradeCluster re-enabled (trend stacking)
#   • CrossBrokerArb re-enabled (spread capture)
#   • HF Scalping Mode auto-enabled
#
# Master switch (set to 1 to enable):
HF_FLIP_MODE=0

# ── Fine-tuning (only needed if you want to override defaults) ──────────────
# FLIP_MIN_RR=1.3                   # Minimum R:R ratio
# FLIP_MIN_NET_PROFIT_PCT=0.4       # Minimum net profit % per trade
# FLIP_PROFIT_GATE_MULTIPLE=1.3     # Net profit gate safety multiple (vs default 2.0)
# FLIP_AI_MIN_WIN_PROB=0.33         # AI win-probability threshold (vs default 0.55)
# FLIP_SNIPER_MIN_CONFIDENCE=0.35   # Sniper filter confidence gate (vs default 0.50)
# FLIP_SNIPER_MIN_ADX=8.0           # Sniper ADX instant-block threshold (vs default 12.0)
# FLIP_AGGRESSION_MODE=AGGRESSIVE   # Aggression mode: SAFE | BALANCED | AGGRESSIVE
# FLIP_MIN_TRADES_PER_HOUR=6        # Minimum target trades per hour
# FLIP_MIN_TRADES_PER_DAY=80        # Minimum target trades per day
# FLIP_CYCLE_SECONDS=20             # Scan cycle interval in seconds
# FLIP_ENABLE_TRADE_CLUSTER=1       # Re-enable Trade Cluster Engine
# FLIP_ENABLE_CROSS_BROKER_ARB=1    # Re-enable Cross-Broker Arbitrage Monitor

# ── Individual subsystem env overrides (applied automatically by flip mode) ─
# NET_PROFIT_SAFETY_MULTIPLE=1.3    # Override net profit gate safety multiple
# NET_PROFIT_MIN_TARGET_PCT=0.004   # Override minimum profit target (as fraction)
# SNIPER_MIN_CONFIDENCE=0.35        # Override sniper filter min confidence
# SNIPER_MIN_ADX=8.0                # Override sniper ADX threshold
# AI_MIN_WIN_PROB=0.33              # Override AI win-probability gate
# AGGRESSION_MODE=AGGRESSIVE        # Override aggression mode
# HF_SCALP_MODE=1                   # Override HF scalping mode switch

# ── Flow Mode thresholds (micro-cap environments — frequent + controlled entries) ──
# AI_MIN_WIN_PROB=0.45              # Flow mode win-prob floor (default 0.45)
# AI_MIN_MODEL_CONF=0.55            # Flow mode model-confidence floor (default 0.55)
# NIJA_MIN_SCORE_ABSOLUTE=16.5      # Flow mode score floor (default 16.5)
# NIJA_WMX_SIGNAL_THRESHOLD=36      # Flow mode WMX signal gate (default 36)
# AGGRESSION_MODE=AGGRESSIVE        # (Optional) kickstart after 10-15 slow cycles

# ============================================================================
# NIJA SCORE & WIN-RATE SETTINGS
# ============================================================================

# Score Distribution Debugger — set to 0 to silence histogram output
NIJA_SCORE_DEBUG=1

# Win-Rate Score Shaper (WRSS) — regime-aware score multiplier
NIJA_WRSS_ENABLED=1

# Named win-rate tier factors (discrete tiered lookup — activates when ALL five are set)
# DOMINATING: win-rate ≥ 75 %  → multiply composite score by this factor
NIJA_WRSS_WINRATE_DOMINATING_FACTOR=1.30
# STRONG: win-rate in [65 %, 75 %)
NIJA_WRSS_WINRATE_STRONG_FACTOR=1.15
# NEUTRAL: win-rate in [45 %, 65 %) — the stable mid-zone
NIJA_WRSS_WINRATE_NEUTRAL_FACTOR=1.05
# STRUGGLING: win-rate in [30 %, 45 %)
NIJA_WRSS_WINRATE_STRUGGLING_FACTOR=0.90
# BROKEN: win-rate < 30 % — heavily dampen entries in this regime
NIJA_WRSS_WINRATE_BROKEN_FACTOR=0.70

# ============================================================================
# SCORE FLOORS — AI Engine tier thresholds (configurable, keep defaults unless tuning)
# ============================================================================
# NIJA_SCORE_FLOOR_FAIR=25.0   # 0.75× position size tier (default 25)
# NIJA_SCORE_FLOOR_GOOD=34.0   # 1.0× position size tier  (default 34)
# NIJA_SCORE_FLOOR_ELITE=75.0  # 1.5× position size tier  (default 75)

# ============================================================================
# MICRO-CAP MODE SETTINGS
# ============================================================================

# ============================================================================
# NIJA AI SCORE & WIN-RATE SHAPING  (Micro-Cap Tuning)
# ============================================================================
# Full documentation: bot/win_rate_score_shaper.py, bot/nija_ai_engine.py,
#                     bot/micro_capital_config.py
#
# Copy this block into your .env to activate micro-cap threshold tuning.
# All values shown are the recommended micro-cap defaults.

# Score histogram debug output (1=enabled, 0=disabled)
NIJA_SCORE_DEBUG=1

# Win-Rate Score Shaper — per-regime score multiplier tiers
NIJA_WRSS_ENABLED=1
NIJA_WRSS_WINRATE_DOMINATING_FACTOR=1.30   # ≥72% win-rate → boost scores 30%
NIJA_WRSS_WINRATE_STRONG_FACTOR=1.15       # ≥60% win-rate → boost scores 15%
NIJA_WRSS_WINRATE_NEUTRAL_FACTOR=1.05      # >45% win-rate → slight upward bias
NIJA_WRSS_WINRATE_STRUGGLING_FACTOR=0.90   # >30% win-rate → dampen scores 10%
NIJA_WRSS_WINRATE_BROKEN_FACTOR=0.70       # ≤30% win-rate → dampen scores 30%

# Score tier floors — position-size multiplier boundaries and histogram bins
# FAIR (48–49) is the borderline band; WRSS boost can push these into GOOD (50+)
NIJA_SCORE_FLOOR_FAIR=48
NIJA_SCORE_FLOOR_GOOD=50
NIJA_SCORE_FLOOR_ELITE=75

# Micro-Cap Compounding — position management and exit levels
NIJA_MICROCAP_RELAX_SIDEWAYS=true          # relax AI gate in consolidation/ranging regimes
NIJA_MICROCAP_MAX_POSITIONS=4
NIJA_MICROCAP_POSITION_SIZE_PERCENT=60.0
NIJA_MICROCAP_STOP_LOSS_PERCENT=1.5
NIJA_MICROCAP_TP1_PERCENT=2.5
NIJA_MICROCAP_TP2_PERCENT=3.5
NIJA_MICROCAP_TP3_PERCENT=6.0
NIJA_MICROCAP_TRAILING_STOP_ACTIVATION_PERCENT=2.5
NIJA_MICROCAP_COOLDOWN_SECONDS=60

# Sideways/consolidation relaxation: when true, reduces cooldown to minimum
# in consolidation/ranging regimes (historically profitable scalp setups)
NIJA_MICROCAP_RELAX_SIDEWAYS=true

# ============================================================================
# ADAPTIVE COMPOUNDING / STREAK BONUS
# ============================================================================

# Enable/disable the per-win streak bonus on profit targets
NIJA_MICROCAP_DYNAMIC_STREAK_ENABLED=true

# Extra % added to profit target per consecutive winning trade
# (e.g. 0.5 → +0.5% per win, capped at 1.0% total bonus)
NIJA_MICROCAP_STREAK_BONUS_MULTIPLIER=0.5

# Streak decay: reset win streak if no new trade is entered within this many
# seconds (momentum has expired). Set to 0 to disable time-based decay.
NIJA_MICROCAP_STREAK_DECAY_SECONDS=300

# Adaptive cooldown: scale re-entry cooldown between min and max based on
# current market volatility (higher volatility → longer cooldown)
NIJA_MICROCAP_ADAPTIVE_COOLDOWN_ENABLED=true
NIJA_MICROCAP_COOLDOWN_MIN_SECONDS=30
NIJA_MICROCAP_COOLDOWN_MAX_SECONDS=120
# Volatility scaling factor: 1.5 means volatility 1.5× normal → max cooldown
NIJA_MICROCAP_COOLDOWN_VOLATILITY_FACTOR=1.5
# ============================================================================

# ============================================================================
# DIAGNOSTIC / SAFETY OVERRIDE — disable in live production
# ============================================================================
# When set to 1 this bypasses all safety gates that would block new entries
# (e.g. capital-scaling engine, drawdown limiter, reconnect guards).
# Use ONLY for controlled testing to verify that the APEX strategy fires.
# MUST remain 0 (default) in live production.
NIJA_BYPASS_SAFETY_USER_MODE=0
# ============================================================================
